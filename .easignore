# EAS Build uses .easignore (when present) instead of .gitignore to decide
# what to upload to the cloud builder. We mirror most of .gitignore here, but
# omit the credential-file globs (*.p12, *.mobileprovision, *.p8, *.key) and
# the /.nooks-build/ scratch dir — those have to ship to the EAS cloud
# runner so the production iOS build can sign locally with credentials.json.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# server env (not needed in app build)
server/.env

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
