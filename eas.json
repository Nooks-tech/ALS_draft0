{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "resourceClass": "m-medium" }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "credentialsSource": "remote",
        "withoutCredentials": true
      },
      "ios": { "resourceClass": "m-medium" }
    },
    "ios-simulator": {
      "extends": "preview",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "withoutCredentials": true
      }
    },
    "production": {
      "ios": {
        "resourceClass": "m-medium",
        "credentialsSource": "local"
      },
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": { "appleId": "abdullah.alsaedi.2003@gmail.com" },
      "android": {
        "serviceAccountKeyPath": "./fastlane/google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
