# Foodics API (required for menu & orders)
FOODICS_API_TOKEN=your_foodics_api_token
FOODICS_API_URL=https://api.foodics.com/v2

# Moyasar - get SECRET key (sk_test_ or sk_live_) from https://moyasar.com/dashboard/
# Publishable key (pk_test_/pk_live_) is for client; server needs secret for creating invoices
MOYASAR_SECRET_KEY=sk_test_your_secret_key
# Required in production for POST /api/payment/webhook
MOYASAR_WEBHOOK_SECRET=replace-with-a-random-webhook-secret

# Alternative: Tap Payments
TAP_SECRET_KEY=sk_test_xxx

# Server
PORT=3001

# Supabase (for OTP storage) - use SERVICE_ROLE key (from Dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# MadarSMS – SMS OTP via api.mobile.net.sa (Orbit Technology)
# Get API key from https://app.mobile.net.sa/
MADAR_SMS_API_KEY=your_madar_api_key
# Registered sender name (must be approved in your MadarSMS account)
MADAR_SMS_SENDER=Nooks

# Payment redirect - public HTTPS URL for success redirect (e.g. https://api.als.delivery)
# Required for Apple Pay web flow to redirect back to app after payment
# PAYMENT_REDIRECT_BASE_URL=https://api.als.delivery

# OTO - delivery dispatch (https://tryoto.com)
# Platform-level fallback token. Per-merchant tokens are stored in merchant_delivery_settings.
OTO_REFRESH_TOKEN=your_refresh_token
# Required in production for POST /api/oto/webhook
OTO_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
# Default carrier filter (per-merchant override via merchant_delivery_settings.preferred_carriers)
OTO_PREFERRED_CARRIERS=careem,mrsool,barq

# Nooks build webhook (Option A – triggers GitHub Actions for Android + iOS EAS builds per merchant)
# Copy into .env. Fill GITHUB_TOKEN (from github.com/settings/tokens, repo scope) and optionally the rest.
GITHUB_TOKEN=
GITHUB_REPO=Nooks-tech/ALS_draft0
GITHUB_BUILD_REF=master
# After deploy: your API base URL (e.g. https://als-api.railway.app) so GET /build returns webhook_url
BUILD_WEBHOOK_BASE_URL=
# Required in production: give the same value to Nooks for x-nooks-secret header
BUILD_WEBHOOK_SECRET=

# Shared server-to-server secret used by nooksweb -> ALS internal routes
NOOKS_INTERNAL_SECRET=replace-with-a-random-shared-secret

# Apple Wallet pass signing
APPLE_PASS_TYPE_ID=pass.space.nooks.loyalty
APPLE_PASS_TEAM_ID=YOUR_TEAM_ID
# Base64-encoded PEM contents so the cert and key are never committed in source.
APPLE_PASS_CERT_BASE64=
APPLE_PASS_KEY_BASE64=
# Optional separate pass auth secret; if omitted the server falls back to NOOKS_INTERNAL_SECRET.
WALLET_AUTH_SECRET=